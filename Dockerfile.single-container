# Single-container production image: Vite frontend + FastAPI backend

FROM node:20-slim AS frontend-build
WORKDIR /frontend

COPY frontend/package*.json ./
RUN if [ -f package-lock.json ]; then npm ci; else npm install; fi

COPY frontend/ ./
ARG VITE_API_BASE_URL=/
ENV VITE_API_BASE_URL=${VITE_API_BASE_URL}
RUN npm run build

FROM python:3.10-slim AS runtime
WORKDIR /app

# System packages for OCR/PDF handling + web serving + process supervision.
RUN apt-get update && apt-get install -y --no-install-recommends \
    tesseract-ocr \
    libtesseract-dev \
    poppler-utils \
    libpoppler-dev \
    nginx \
    supervisor \
    curl \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt
RUN pip install --no-cache-dir fastapi "uvicorn[standard]" python-multipart

# Copy backend/application source.
COPY . .

# Copy built frontend into Nginx web root.
COPY --from=frontend-build /frontend/dist /usr/share/nginx/html

# Runtime config for reverse proxy and process manager.
COPY deploy_single_container/nginx.conf /etc/nginx/conf.d/default.conf
COPY deploy_single_container/supervisord.conf /etc/supervisor/conf.d/supervisord.conf

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --retries=6 --start-period=30s \
  CMD curl -fsS http://127.0.0.1:8080/api/status || exit 1

CMD ["supervisord", "-c", "/etc/supervisor/conf.d/supervisord.conf"]
